{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["DOM", "ES2017"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "moduleResolution": "node",
    "typeRoots": ["./types"],
    "skipLibCheck": true
  },
  "include": ["**/*.ts", "types/**/*.d.ts", "public/**/*.js"],
  "exclude": ["node_modules"]
}
