{
  "name": "zombie-multiplayer-game",
  "version": "1.0.0",
  "description": "Jeu de zombie multijoueur en temps réel sur navigateur",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "deploy:server": "node deploy-server.js",
    "deploy:install": "cp com.zombiegame.deploy.plist ~/Library/LaunchAgents/ && launchctl load ~/Library/LaunchAgents/com.zombiegame.deploy.plist",
    "deploy:uninstall": "launchctl unload ~/Library/LaunchAgents/com.zombiegame.deploy.plist && rm ~/Library/LaunchAgents/com.zombiegame.deploy.plist",
    "deploy:restart": "launchctl stop com.zombiegame.deploy && launchctl start com.zombiegame.deploy",
    "deploy:logs": "tail -f deploy.log",
    "db:migrate": "node database/scripts/migrate.js up",
    "db:rollback": "node database/scripts/migrate.js down",
    "db:status": "node database/scripts/migrate.js status",
    "health": "curl -sf http://localhost:${PORT:-3000}/health | node -e \"const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));console.log('status:',d.status);process.exit(d.status==='ok'?0:1)\"",
    "prepare": "husky"
  },
  "keywords": [
    "game",
    "zombie",
    "multiplayer",
    "websocket"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "compression": "^1.7.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.6.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "canvas": "^3.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.0.1",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.3"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
