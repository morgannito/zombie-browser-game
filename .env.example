# Zombie Game - Environment Variables Configuration
# Copy this file to .env and configure for your environment

# ===============================================
# SERVER CONFIGURATION
# ===============================================

# Server port
PORT=3000

# Node environment (development | production)
NODE_ENV=development

# ===============================================
# SECURITY CONFIGURATION
# ===============================================

# Allowed CORS origins (comma-separated)
# IMPORTANT: Must include ALL domains where your app is hosted (both http and https)
# For WebSocket connections to work, this MUST match the domain in the browser
# Example: https://yourdomain.com,https://www.yourdomain.com
# Production: Include wss:// protocol domain as https:// (e.g., https://zombie.lonewolf.fr)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===============================================
# DATABASE CONFIGURATION
# ===============================================

# SQLite database path
DB_PATH=./data/game.db

# ===============================================
# LOGGING CONFIGURATION
# ===============================================

# Log level (error | warn | info | debug)
# Use 'info' in production, 'debug' in development
LOG_LEVEL=debug

# Log directory for file output (production only)
LOG_DIR=./logs

# ===============================================
# AUTHENTICATION (REQUIRED FOR PRODUCTION)
# ===============================================

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# IMPORTANT: Generate a unique secret for production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NEVER commit a real secret here — this file is version-controlled
JWT_SECRET=CHANGE_ME_BEFORE_RUNNING

# JWT Expiration (e.g., 24h, 7d, 30d)
JWT_EXPIRES_IN=7d

# ===============================================
# RATE LIMITING
# ===============================================

# API rate limit window (milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# API rate limit max requests per window
RATE_LIMIT_MAX=100

# ===============================================
# PERFORMANCE OPTIMIZATION
# ===============================================

# Performance mode - optimizes server for different resource constraints
# Options: high | balanced | low-memory | minimal
#
# high:       60 FPS, 200 zombies, 50 players (recommended for powerful servers)
# balanced:   45 FPS, 150 zombies, 30 players (default - good balance)
# low-memory: 30 FPS, 100 zombies, 20 players (for VPS with limited RAM)
# minimal:    20 FPS,  50 zombies, 10 players (extreme resource constraints)
PERFORMANCE_MODE=balanced

# ===============================================
# METRICS & MONITORING
# ===============================================

# Bearer token protecting /api/v1/metrics and /health endpoints
# REQUIRED in production — missing token blocks all metric scraping
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Usage header: Authorization: Bearer <METRICS_TOKEN>
# Development: leave empty to allow unauthenticated access
METRICS_TOKEN=

# ===============================================
# ADMIN ACCESS
# ===============================================

# Comma-separated UUIDs of players with in-game admin commands
# Find UUIDs: SELECT id FROM players WHERE username = 'yourname';
# Example: ADMIN_USER_IDS=uuid-1,uuid-2,uuid-3
# Leave empty to disable all admin commands
ADMIN_USER_IDS=

# ===============================================
# SESSION CONFIGURATION
# ===============================================

# Idle session TTL in milliseconds before socket disconnect
# Default: 300000 (5 min). Separate from JWT_EXPIRES_IN (auth token lifetime).
# Increase for casual play, decrease to reclaim server memory faster.
SESSION_TTL=300000

# ===============================================
# FEATURE FLAGS (Development / Testing)
# ===============================================

# Enable verbose admin debug logs (true | false)
ADMIN_DEBUG=false

# Skip database initialization (true | false) — useful for CI without DB
DB_SKIP=false

# Disable JWT auth during tests (true | false) — NEVER set true in production
DISABLE_AUTH_FOR_TESTS=false

# Bypass the 20 req / 15 min auth rate limiter (CI / integration tests only).
# Automatically ignored when NODE_ENV=production.
DISABLE_AUTH_RATE_LIMIT=0

# Enable MessagePack binary protocol for WebSocket (true | false)
ENABLE_MSGPACK=false

# Enable game replay recording (true | false)
ENABLE_REPLAY=false

# Enable server-side anti-cheat checks (true | false) — recommended in prod
ENABLE_ANTICHEAT=true

# Enable WebSocket permessage-deflate compression (true | false)
ENABLE_WS_COMPRESSION=false

# Require database connection on startup (true | false)
REQUIRE_DATABASE=true

# Force dev-mode script tags even when NODE_ENV=production (true | false).
# Bypasses the app.bundle.js injection — useful for debugging prod bundles.
DEV_MODE=false
